# Copy to .env (gitignored — never commit real secrets) and fill in. Generate strong
# random values, e.g.:
#   NETBOX_SECRET_KEY:            openssl rand -base64 50
#   POSTGRES_PASSWORD:            openssl rand -hex 24
#   NETBOX_SUPERUSER_PASSWORD:    openssl rand -hex 24
#   NETBOX_API_TOKEN:             openssl rand -hex 20   (40 hex chars; shared by NetBox + Argus)

# --- NetBox (bundled) ---
NETBOX_IMAGE=netboxcommunity/netbox:v4.6-5.0.1
NETBOX_SECRET_KEY=
POSTGRES_PASSWORD=
NETBOX_SUPERUSER_PASSWORD=
NETBOX_API_TOKEN=

# --- UniFi (live discovery source) ---
# UNIFI_URL is the controller base URL (e.g. https://10.0.0.1).
UNIFI_URL=
UNIFI_API_TOKEN=
UNIFI_SITE=default

# --- Optional: API auth ---
# Require "Authorization: Bearer <token>" on /api + /webhooks. Unset = open (default).
# The same value reaches both argus-server (which enforces it) and argus-web (whose nginx
# forwards it on the dashboard's /api proxy), so the dashboard keeps working — also
# uncomment the HTTP_TOKEN line on argus-server in docker-compose.yml. Configure the
# NetBox webhook to send the matching header.
HTTP_TOKEN=

# --- Optional: scheduled drift discovery (read-only; off by default) ---
# SCHEDULE_INTERVAL is seconds between cycles; 0/unset disables it (e.g. 300 = 5 min).
# Uncomment the matching lines on argus-server in docker-compose.yml to take effect.
SCHEDULE_INTERVAL=0
SCHEDULE_COLLECTOR=unifi
# Set to also POST a Slack-compatible {"text": ...} alert when drift is detected.
ALERT_WEBHOOK_URL=
