# Copy to .env and fill in. Generate strong random values, e.g.:
#   NETBOX_SECRET_KEY:            openssl rand -base64 50
#   POSTGRES_PASSWORD:            openssl rand -hex 24
#   NETBOX_SUPERUSER_PASSWORD:    openssl rand -hex 24
#   NETBOX_API_TOKEN:             openssl rand -hex 20   (40 hex chars; shared by NetBox + Argus)

# --- NetBox (bundled) ---
NETBOX_IMAGE=netboxcommunity/netbox:v4.2-3.2.1
NETBOX_SECRET_KEY=
POSTGRES_PASSWORD=
NETBOX_SUPERUSER_PASSWORD=
NETBOX_API_TOKEN=

# --- UniFi (live discovery source) ---
# UNIFI_URL is the controller base URL (e.g. https://10.10.88.1).
UNIFI_URL=
UNIFI_API_TOKEN=
UNIFI_SITE=default
