# NetBox connection (source of truth)
NETBOX_URL=https://netbox.lan
NETBOX_TOKEN=
NETBOX_VERIFY_SSL=true

# UniFi Network controller (discovery collector — Integration API token)
UNIFI_URL=https://192.168.1.1
UNIFI_API_TOKEN=
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false

# HTTP server (FastAPI, used by the web app)
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
