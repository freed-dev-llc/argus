# Argus server config. Copy to .env (gitignored) and fill in — never commit real secrets.
# Values are also read from the process environment if you prefer to export them instead.

# NetBox connection (source of truth)
NETBOX_URL=https://netbox.lan
NETBOX_TOKEN=
NETBOX_VERIFY_SSL=true

# UniFi Network controller (discovery collector — Integration API token)
UNIFI_URL=https://192.168.1.1
UNIFI_API_TOKEN=
# Site to discover (internalReference). Empty, "*", or "all" → discover every site on the
# controller (multi-site, opt-in); any other value → just that one site.
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false

# SNMP/LLDP collector (generic, non-UniFi gear). Comma-separated host[:community].
# Needs the 'discovery' extra: pip install 'argus-netbox[discovery]'
SNMP_TARGETS=
SNMP_COMMUNITY=public

# HTTP server (FastAPI, used by the web app)
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Optional API auth: require "Authorization: Bearer <token>" on /api and /webhooks.
# Unset = open (default). When set, the dashboard's nginx forwards it and NetBox
# webhooks must send the matching header.
HTTP_TOKEN=

# Optional NetBox webhook authenticity: verify the X-Hook-Signature HMAC (HMAC-SHA512 of the
# raw body) on POST /webhooks/netbox. Set this to the matching NetBox webhook "secret".
# Unset = no verification (default). Additive to HTTP_TOKEN; both apply when both are set.
NETBOX_WEBHOOK_SECRET=

# Optional scheduled drift discovery (in-process, read-only — no writes/reconcile).
# SCHEDULE_INTERVAL is seconds between cycles; 0/unset disables it (e.g. 300 = 5 min).
# The latest outcome is exposed at GET /api/drift/status.
SCHEDULE_INTERVAL=0
SCHEDULE_COLLECTOR=unifi
# Optional: also POST a Slack-compatible {"text": ...} alert when drift is detected.
ALERT_WEBHOOK_URL=
